# Safe template only — copy to a private path on the Droplet (e.g. deploy/.env).
# Do NOT commit real credentials. Do NOT paste secrets into chat or tickets.
#
# Copy:  cp collector.env.example /opt/your-app/deploy/.env
# Then edit the copy, chmod 600 the copy, and point systemd EnvironmentFile= at it.
#
# Private keys must stay OUTSIDE the git tree. chmod 600 PEM/key files.
# Committed files must use placeholders only.

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
KALSHI_ENV=prod
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO
