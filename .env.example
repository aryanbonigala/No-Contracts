# Copy to .env and fill in locally — never commit .env

# Runtime / logging
KALSHI_NO_CARRY_ENV=production
LOG_LEVEL=INFO

# Kalshi HTTP API (URLs only; credentials via env or separate secret store in later phases)
KALSHI_API_BASE_URL=https://api.elections.kalshi.com
# Kalshi auth placeholders (required once signed requests are implemented)
KALSHI_API_KEY_ID=your_live_key_id_here
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi-private-key.pem
# Alternative to file path (raw PEM text):
# KALSHI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----..."

# PostgreSQL (DigitalOcean managed DB or local Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Optional: overrides for research defaults (comma-separated ISO8601 boundaries, if used later)
# RESEARCH_AS_OF_UTC=
