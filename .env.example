# Copy to .env and fill in locally — never commit .env

# Application runtime
KALSHI_NO_CARRY_ENV=development
LOG_LEVEL=INFO

# Kalshi Trade API v2 host selection
# Use prod API (default) or switch to demo API host via KALSHI_ENV=demo
KALSHI_ENV=prod
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_DEMO_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# Optional: authenticated read-only calls (RSA private key PEM on disk)
# Leave blank for public market data only.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_REQUEST_TIMEOUT_SECONDS=20

# Legacy alias (optional): KALSHI_API_BASE_URL is accepted as an alias for KALSHI_BASE_URL

# PostgreSQL — optional until you run scripts/init_db.py
# Use a managed DB URL (DigitalOcean, RDS, etc.) in production.
# For DO Managed DB over the public network, prefer TLS, e.g. ?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Optional: enable postgres integration test (pytest) — off by default
# RUN_DB_INTEGRATION_TESTS=1
